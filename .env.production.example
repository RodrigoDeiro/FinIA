# =============================================================================
# FinIA — Variáveis de PRODUÇÃO (copie para .env.production e preencha)
# =============================================================================
#   cp .env.production.example .env.production
#   # gere segredos com: openssl rand -hex 32   (ou -hex 64 para o JWT)
#
# Suba com:
#   docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
# =============================================================================

# ─── Banco de dados ───────────────────────────────────────────────────────────
POSTGRES_USER=finia
POSTGRES_PASSWORD=CHANGE_ME_forte
POSTGRES_DB=finia_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_forte

# ─── Segurança ────────────────────────────────────────────────────────────────
# openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_hex

# ─── URL pública ──────────────────────────────────────────────────────────────
# Onde os usuários acessam o dashboard. Os magic links usam esta base.
# Local: http://localhost:3000  |  Nuvem: https://seu-dominio.com
APP_URL=http://localhost:3000

# ─── WhatsApp (Evolution API) ─────────────────────────────────────────────────
EVOLUTION_API_KEY=CHANGE_ME_forte
EVOLUTION_INSTANCE_NAME=finia
# openssl rand -hex 32  (assina os webhooks Evolution → FinIA)
EVOLUTION_WEBHOOK_SECRET=CHANGE_ME_32_hex
# URL pública da Evolution (só relevante se expor o manager na internet)
EVOLUTION_PUBLIC_URL=http://localhost:8080

# ─── IA (Anthropic) ───────────────────────────────────────────────────────────
# Opcional: sem chave, mensagens ambíguas recebem "não entendi" (degrada bem).
ANTHROPIC_API_KEY=sk-ant-...
