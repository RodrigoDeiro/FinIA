# =============================================================================
# FinIA Backend — Dockerfile de Desenvolvimento
# =============================================================================
#
# Estratégia de layers (ordem importa para cache do Docker):
#
#   Layer 1 — node:22-alpine   → rebuilt: nunca (imagem base fixada)
#   Layer 2 — package*.json   → rebuilt: quando dependências mudam
#   Layer 3 — prisma/         → rebuilt: quando schema.prisma muda
#   Layer 4 — npm install     → rebuilt: quando layers 2 ou 3 mudam
#
# O código-fonte (src/) NÃO é copiado aqui.
# Ele chega via volume mount definido no docker-compose.yml:
#   ./backend:/app             → hot reload funciona via inotify
#   backend_node_modules:/app/node_modules → node_modules isolados do host
#
# PRÉ-REQUISITO:
#   prisma/schema.prisma deve existir antes de rodar docker-compose up --build
#   O postinstall ("prisma generate") exige o schema para gerar o Prisma Client.
#   Crie o schema primeiro, depois construa a imagem.
#
# WORKFLOW APÓS ALTERAR schema.prisma:
#   1. docker-compose exec backend npx prisma generate  (sem rebuild)
#   2. docker-compose exec backend npx prisma migrate dev
#   Ou rebuild completo: docker-compose up --build backend
#
# =============================================================================

FROM node:22-alpine

# ─── Dependências do sistema ──────────────────────────────────────────────────
# wget: usado pelo healthcheck do docker-compose ("wget -q --spider /health")
# Mantemos a imagem mínima: sem curl, sem bash, sem ferramentas extras
RUN apk add --no-cache wget

# ─── Diretório de trabalho ────────────────────────────────────────────────────
WORKDIR /app

# ─── Layer de dependências (package files) ────────────────────────────────────
# Copiados antes do src/ para aproveitar o cache do Docker.
# Este layer só é invalidado quando package.json ou package-lock.json mudam.
COPY package*.json ./

# ─── Layer do Prisma ──────────────────────────────────────────────────────────
# schema.prisma é necessário para o postinstall ("prisma generate").
# Este layer é invalidado quando o schema muda, forçando regeneração do client.
#
# Em runtime, o volume mount ./backend:/app sobrescreve esta cópia com a versão
# atual do host — sempre sincronizado com o desenvolvimento.
COPY prisma ./prisma/

# ─── Instalação de dependências ───────────────────────────────────────────────
# npm install executa o postinstall automaticamente:
#   postinstall → prisma generate → gera /app/node_modules/.prisma/client
#
# O node_modules gerado aqui é preservado pelo volume nomeado
# "backend_node_modules" no docker-compose.yml, garantindo que:
#   - Binários nativos compilados para Linux/Alpine sejam usados em runtime
#   - node_modules do host (Mac/Windows) não sobrescrevam os do container
RUN npm install

# ─── Porta ────────────────────────────────────────────────────────────────────
# Documentada aqui; o binding real é feito no docker-compose.yml
EXPOSE 3000

# ─── Variáveis de ambiente padrão ─────────────────────────────────────────────
ENV NODE_ENV=development

# CHOKIDAR_USEPOLLING=false → usa inotify (Linux nativo, eficiente)
# Se o hot reload não funcionar no macOS com Docker Desktop,
# adicione CHOKIDAR_USEPOLLING=true ao .env
ENV CHOKIDAR_USEPOLLING=false

# ─── Comando de inicialização ─────────────────────────────────────────────────
# node_modules/.bin/tsx em vez de npx tsx:
#   - Sem overhead de resolução do npx (~200ms)
#   - tsx vira PID 1 → recebe SIGTERM diretamente → graceful shutdown correto
#
# tsx watch:
#   - Executa TypeScript sem compilação prévia (esbuild internamente)
#   - Monitora src/ via inotify para hot reload (< 500ms por alteração)
#   - Respeita tsconfig.json: paths aliases e moduleResolution NodeNext
CMD ["node_modules/.bin/tsx", "watch", "src/server.ts"]
