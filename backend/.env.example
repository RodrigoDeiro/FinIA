# =============================================================================
# FinIA Backend — Variáveis de Ambiente
# =============================================================================
#
# Setup:
#   cp .env.example .env
#   # Edite .env substituindo todos os valores marcados com _change_me
#
# REGRAS:
#   - Nunca comite .env no repositório (.gitignore já o exclui)
#   - Este arquivo (.env.example) não deve conter segredos reais
#   - Variáveis marcadas com [docker-override] são sobrescritas pelo
#     docker-compose.yml quando o backend roda dentro da rede Docker.
#     O valor aqui é usado apenas ao rodar o backend fora do Docker (npm run dev local).
#
# GERAR SECRETS:
#   openssl rand -hex 32    → para secrets de 256 bits (webhook, JWT curto)
#   openssl rand -hex 64    → para secrets de 512 bits (JWT principal)
#
# =============================================================================


# ─── Aplicação ────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug


# ─── PostgreSQL ───────────────────────────────────────────────────────────────

POSTGRES_USER=finia
POSTGRES_PASSWORD=finia_secret_change_me
POSTGRES_DB=finia_db

# [docker-override] docker-compose.yml substitui localhost por postgres
DATABASE_URL="postgresql://finia:finia_secret_change_me@localhost:5432/finia_db?schema=public"


# ─── Redis ────────────────────────────────────────────────────────────────────

REDIS_PASSWORD=redis_secret_change_me

# [docker-override] docker-compose.yml substitui localhost por redis
REDIS_URL="redis://:redis_secret_change_me@localhost:6379"


# ─── WhatsApp — Evolution API ─────────────────────────────────────────────────
# Sprint 1+
# Documentação: https://doc.evolution-api.com

EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key_change_me
EVOLUTION_INSTANCE_NAME=finia
EVOLUTION_WEBHOOK_SECRET=your_webhook_secret_change_me

# Valores: evolution | meta
WHATSAPP_PROVIDER=evolution


# ─── IA — Anthropic Claude ────────────────────────────────────────────────────
# Sprint 2+
# Obtenha em: https://console.anthropic.com

ANTHROPIC_API_KEY=sk-ant-your_key_here


# ─── Segurança — JWT ──────────────────────────────────────────────────────────
# Sprint 3+ (autenticação web).
#
# Deixe JWT_SECRET COMENTADO no Sprint 1: ele é opcional aqui e o servidor sobe
# sem ele. Quando chegar no Sprint 3, descomente e gere um valor forte:
#   openssl rand -hex 64
# (se preenchido, precisa ter no mínimo 32 caracteres — placeholders curtos
#  fazem o boot falhar de propósito, para não usar segredo fraco.)
#
# JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d


# ─── Aplicação — URLs ─────────────────────────────────────────────────────────
# Sprint 3+

APP_URL=http://localhost:5173


# ─── Storage — Relatórios ─────────────────────────────────────────────────────
# Sprint 4+

STORAGE_PATH=./storage/reports


# ─── Ferramentas de Desenvolvimento ──────────────────────────────────────────

PGADMIN_DEFAULT_EMAIL=admin@finia.local
PGADMIN_DEFAULT_PASSWORD=admin

REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin


# ─── Hot Reload ───────────────────────────────────────────────────────────────
# false → inotify (Linux nativo)
# true  → polling (necessário no macOS com Docker Desktop em alguns casos)

CHOKIDAR_USEPOLLING=false
